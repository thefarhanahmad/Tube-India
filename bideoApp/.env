# Local development config (this machine's LAN IP so the device on the same Wi-Fi can reach the API).
# For installed/standalone builds the hosted URL is injected via eas.json instead.
# EXPO_PUBLIC_API_URL=http://192.168.3.102:5000/api

# Hosted backend (used by builds, kept here for reference):
EXPO_PUBLIC_API_URL=https://bideo.in/api

# Feature flag: turn Google login on/off without code changes. "false" hides the Google button.
EXPO_PUBLIC_GOOGLE_LOGIN_ENABLED=false

EXPO_PUBLIC_GOOGLE_CLIENT_ID=152580538880-fog08crgbv0sj7jrk87v5vs0pdv4puli.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=152580538880-65c7738po50m0jg0nn1ia9qt5klod3vm.apps.googleusercontent.com
