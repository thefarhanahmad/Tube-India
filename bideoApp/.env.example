# Base URL of the Bideo backend API (include the /api suffix).
# Dev: your machine's LAN IP so a device on the same Wi-Fi can reach it (e.g. http://192.168.1.10:5000/api).
# Builds: set the hosted URL here or via eas.json (e.g. https://tube-india.onrender.com/api).
EXPO_PUBLIC_API_URL=http://192.168.1.10:5000/api

# Feature flag for Google login. "true" shows the Google button, "false" hides it.
EXPO_PUBLIC_GOOGLE_LOGIN_ENABLED=false

# Google OAuth client IDs (web + android) used by expo-auth-session.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
