{
  "expo": {
    "name": "Bideo",
    "slug": "bideoApp",
    "scheme": "bideo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon.png",
      "bundleIdentifier": "com.farhan.bideoapp"
    },
    "android": {
      "package": "com.farhan.bideoapp",
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash_screen.png",
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "backgroundColor": "#FFFFFF"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to upload business images.",
          "cameraPermission": "The app accesses your camera to take photos for uploads."
        }
      ],
      "expo-web-browser",
      "expo-video"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "ADMOB_BANNER_ID": "ca-app-pub-3940256099942544/6300978111",
      "eas": {
        "projectId": "fdae7a54-8b7f-4cd8-8585-3d169174ee84"
      }
    }
  }
}
