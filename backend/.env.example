# Server
PORT=5000
NODE_ENV=development
MONGODB_URI= # MongoDB connection string (e.g. mongodb+srv://user:pass@cluster.mongodb.net/dbname)

# JWT / Auth
JWT_SECRET= # Strong random secret used to sign JWTs (KEEP PRIVATE)
JWT_EXPIRE=30d # token lifetime (e.g. 30d)
JWT_COOKIE_EXPIRE=30 # cookie expiry (days)

# Frontend / Expo
CLIENT_URL=http://localhost:19006 # allowed frontend origin (used for CORS)
EXPO_PUBLIC_API_URL=http://192.168.3.108:5000/api # Expo app API base URL (used in client)
EXPO_PUBLIC_GOOGLE_CLIENT_ID= # Public Google OAuth Client ID used by the mobile app (web client id for Expo)

# Admin login credentials (set these in your local .env for admin dashboard access)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Google OAuth (backend - KEEP SECRET)
GOOGLE_CLIENT_ID= # Backend OAuth client ID (from Google Cloud Console)
GOOGLE_CLIENT_SECRET= # Backend OAuth client secret (only on server)

# Cloudinary (for media uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Notes:
# - Do NOT commit real secrets to source control. Use a secrets manager or CI environment variables in production.
# - EXPO_PUBLIC_* keys are safe to be public (Expo exposes them to the client). GOOGLE_CLIENT_SECRET must remain on the backend.
# - After setting these, run the backend and Expo app; configure Google Cloud Console redirect URIs as described in google_login.txt
